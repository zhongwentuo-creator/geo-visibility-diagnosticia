# Kimi / Moonshot AI (LLM reasoning: Stages 1/3/7/9)
KIMI_API_KEY=sk-your-kimi-key-here
KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions

# Doubao (AI search testing: Stage 4)
# Note: Uses Responses API, not Chat Completions
DOUBAO_API_KEY=ark-your-doubao-key-here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-evolving

# OpenAI (Alternative LLM)
OPENAI_API_KEY=sk-your-openai-key-here

# Search APIs (Optional, for Stage 6 sentiment scraping)
SERPAPI_KEY=your-serpapi-key
BING_SEARCH_KEY=your-bing-key

# Runtime parameters
DEFAULT_PLATFORM=doubao
MAX_CONCURRENT_SEARCHES=3
REQUEST_TIMEOUT=60
MAX_RETRIES=2
DEBUG=false
LOG_LEVEL=INFO
